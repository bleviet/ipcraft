# package_ip.tcl
# Generated by ipcraft VHDL Generator
# 
# Usage:
#   vivado -mode batch -source package_ip.tcl -tclargs [--update | --clean]

# ------------------------------------------------------------------------------
# Configuration Options
# ------------------------------------------------------------------------------
array set config {
    part         "xc7z020clg400-1"
    ip_name      "{{ entity_name }}"
    vendor       "{{ vendor }}"
    library      "{{ library }}"
    version      "{{ version }}"
    display_name "{{ display_name }}"
    description  "{{ description }}"
    taxonomy     "/UserIP"
    root_dir     ".."
    src_dir      "../rtl"
    top          "{{ entity_name }}"
}

# ------------------------------------------------------------------------------
# Procedures
# ------------------------------------------------------------------------------

proc parse_args {argc argv} {
    set mode "update"
    for {set i 0} {$i < $argc} {incr i} {
        set arg [lindex $argv $i]
        switch -exact -- $arg {
            "--update" { set mode "update" }
            "--clean"  { set mode "clean" }
            default {
                puts "Warning: Unknown argument $arg"
            }
        }
    }
    return $mode
}

proc require_arg {key} {
    global config
    if {![info exists config($key)] || $config($key) == ""} {
        puts "ERROR: Required configuration parameter '$key' is missing."
        exit 1
    }
}

proc discover_files {src_dir} {
    set files [glob -nocomplain [file join $src_dir *.vhd] [file join $src_dir *.v] [file join $src_dir *.sv]]
    set files [lsort $files]
    if {[llength $files] == 0} {
        puts "ERROR: No RTL source files discovered in $src_dir"
        exit 1
    }
    return $files
}

proc create_temp_project {part top files} {
    puts "Creating temporary Vivado project..."
    set proj_dir ".build/package_ip"
    catch { file delete -force $proj_dir }
    create_project -force temp_pkg_proj $proj_dir -part $part
    
    puts "Adding source files..."
    read_vhdl $files
    
    set_property top $top [current_fileset]
    update_compile_order -fileset sources_1
}

proc package_new_core {root_dir vendor library taxonomy} {
    puts "Packaging new core..."
    file mkdir $root_dir
    ipx::package_project -root_dir $root_dir -vendor $vendor -library $library -taxonomy $taxonomy -force
}

proc open_existing_core {root_dir} {
    set xml_path [file join $root_dir component.xml]
    if {![file exists $xml_path]} {
        puts "ERROR: Update mode requested but $xml_path does not exist."
        exit 1
    }
    puts "Opening existing core: $xml_path"
    ipx::open_core $xml_path
}

proc apply_core_metadata {} {
    global config
    puts "Applying core metadata..."
    set core [ipx::current_core]
    set_property name $config(ip_name) $core
    set_property version $config(version) $core
    set_property display_name $config(display_name) $core
    set_property description $config(description) $core
    
    # Ensure taxonomy is set correctly
    set_property taxonomy $config(taxonomy) $core
    
    # Generic compatibility for fallback
    set_property supported_families {zynq Production zynquplus Production} $core
}

proc merge_changes_if_needed {} {
    puts "Merging project changes (files and ports)..."
    ipx::merge_project_changes files [ipx::current_core]
    ipx::merge_project_changes ports [ipx::current_core]
}

proc generate_packaging_outputs {} {
    puts "Generating packaging outputs..."
    ipx::create_xgui_files [ipx::current_core]
    ipx::update_checksums [ipx::current_core]
    
    puts "Running integrity check..."
    ipx::check_integrity -quiet [ipx::current_core]
    
    puts "Saving packaged core..."
    ipx::save_core [ipx::current_core]
}

proc verify_packaged_outputs {root_dir} {
    set pass 1
    
    set xml_file [file join $root_dir component.xml]
    if {![file exists $xml_file]} {
        puts "ERROR: Packaged output $xml_file missing."
        set pass 0
    }
    
    set xgui_dir [file join $root_dir xgui]
    if {![file isdirectory $xgui_dir]} {
        puts "ERROR: Packaged XGUI directory $xgui_dir missing."
        set pass 0
    }
    
    if {$pass == 0} {
        puts "ERROR: Package output verification failed."
        exit 1
    } else {
        puts "Package outputs successfully verified."
    }
}

proc cleanup_temp_project {} {
    puts "Cleaning up..."
    close_project
}

# ------------------------------------------------------------------------------
# Main Flow
# ------------------------------------------------------------------------------
puts "Starting IP Packaging Flow..."

set mode [parse_args $argc $argv]
puts "Selected Mode: $mode"

require_arg "part"
require_arg "ip_name"
require_arg "vendor"
require_arg "root_dir"
require_arg "src_dir"
require_arg "top"

set rtl_files [discover_files $config(src_dir)]

create_temp_project $config(part) $config(top) $rtl_files

if {$mode == "update" && [file exists [file join $config(root_dir) component.xml]]} {
    open_existing_core $config(root_dir)
    merge_changes_if_needed
} else {
    package_new_core $config(root_dir) $config(vendor) $config(library) $config(taxonomy)
}

apply_core_metadata
generate_packaging_outputs
verify_packaged_outputs $config(root_dir)

cleanup_temp_project

puts "================================================="
puts " IP Packaging completed successfully! "
puts "================================================="
exit 0
